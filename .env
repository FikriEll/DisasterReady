# ─────────────────────────────────────────────────────────────────────────────
# DisasterReady — Environment Variables Template
# Copy to .env and fill in your values
# JANGAN commit file .env ke GitHub!
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://disasterready-b991b-default-rtdb.asia-southeast1.firebasedatabase.app

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Untuk demo: kirim notifikasi ke grup Telegram ini
TELEGRAM_DEMO_CHAT_ID=-1001234567890

# ── OpenRouteService (GIS Routing) ────────────────────────────────────────────
OPENROUTESERVICE_API_KEY=eyJhbGciOiJIUzI1NiJ9...
ORS_BASE_URL=https://api.openrouteservice.org

# ── WhatsApp Business API (Opsional — untuk produksi) ─────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v18.0

# ── Twilio SMS (Fallback) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+628xxxxxxxx

# ── BMKG API ──────────────────────────────────────────────────────────────────
BMKG_BASE_URL=https://data.bmkg.go.id/DataMKG/MEWS/DigitalForecast
BMKG_EARTHQUAKE_URL=https://data.bmkg.go.id/DataMKG/TEWS
BMKG_RAINFALL_URL=https://data.bmkg.go.id/DataMKG

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-to-a-secure-random-key-32-chars
DEBUG=true

# ── Simulation Mode ───────────────────────────────────────────────────────────
# Set ke 'true' untuk menggunakan data sintetis (lomba demo)
SIMULATION_MODE=true
SIMULATION_SPEED_MULTIPLIER=60   # 1 menit real-time = 1 detik simulasi
