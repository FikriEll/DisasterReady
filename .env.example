# ─────────────────────────────────────────────────────────────────────────────
# DisasterReady — Environment Variables Template
# Copy to .env and fill in your values
# JANGAN commit file .env ke GitHub!
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq API (Primary LLM — Gratis) ──────────────────────────────────────────
# Dapatkan di: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── Firebase ──────────────────────────────────────────────────────────────────
# Dapatkan di: https://console.firebase.google.com → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ── Telegram Bot (Primary Notification Channel — Gratis) ─────────────────────
# 1. Buat bot: Telegram → @BotFather → /newbot
# 2. Dapatkan token dari BotFather
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID tujuan notifikasi demo
# Cara cek chat_id: kirim pesan ke bot, lalu cek https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_DEMO_CHAT_ID=-1001234567890   # Negatif = grup; Positif = personal/channel

# ── OpenRouteService (GIS Routing — Gratis) ───────────────────────────────────
# Daftar gratis di: https://openrouteservice.org/sign-up
OPENROUTESERVICE_API_KEY=eyJhbGciOiJIUzI1NiJ9...
ORS_BASE_URL=https://api.openrouteservice.org

# ── BMKG API (Resmi & Gratis) ─────────────────────────────────────────────────
BMKG_BASE_URL=https://data.bmkg.go.id/DataMKG/MEWS/DigitalForecast
BMKG_EARTHQUAKE_URL=https://data.bmkg.go.id/DataMKG/TEWS
BMKG_RAINFALL_URL=https://data.bmkg.go.id/DataMKG

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-to-a-secure-random-key-32-chars
DEBUG=true

# ── Simulation Mode (Real vs Dummy Data) ──────────────────────────────────────
# SIMULATION_MODE=true : Menggunakan data cuaca sintetik/dummy (Skenario Demo)
# SIMULATION_MODE=false: Menggunakan data cuaca REAL dari BMKG Open API (data.bmkg.go.id)
SIMULATION_MODE=true
SIMULATION_SPEED_MULTIPLIER=60   # 1 menit real-time = 1 detik simulasi
